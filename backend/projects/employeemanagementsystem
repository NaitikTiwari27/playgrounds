cursor = conn.cursor()

def show_all():
    cursor.execute("SELECT * FROM emp")
    rows = cursor.fetchall()

    print("\nEMPLOYEE LIST")
    print("EMPNO\tNAME\tDEPT\tSALARY")
    print("-" * 40)

    for row in rows:
        print(row[0], "\t", row[1], "\t", row[2], "\t", row[3])

    print(f"\nTOTAL RECORDS: {len(rows)}\n")


def add_employee():
    eno = int(input("Enter Employee Number: "))
    name = input("Enter Name: ")
    dept = input("Enter Department: ")
    salary = int(input("Enter Salary: "))

    cursor.execute(
        f"INSERT INTO emp VALUES ({eno}, '{name}', '{dept}', {salary})"
    )
    conn.commit()
    print("Employee added successfully!\n")


def search_employee():
    eno = int(input("Enter Employee Number to Search: "))

    cursor.execute(f"SELECT * FROM emp WHERE empno={eno}")
    row = cursor.fetchone()

    if row:
        print("\nEMPNO\tNAME\tDEPT\tSALARY")
        print("-" * 40)
        print(row[0], "\t", row[1], "\t", row[2], "\t", row[3], "\n")
    else:
        print("No employee found!\n")


def edit_employee():
    eno = int(input("Enter Employee Number to Edit: "))

    cursor.execute(f"SELECT * FROM emp WHERE empno={eno}")
    row = cursor.fetchone()

    if row:
        print(f"Current Dept: {row[2]}, Salary: {row[3]}")

        dept = input("Enter new Department: ")
        salary = int(input("Enter new Salary: "))

        cursor.execute(
            f"UPDATE emp SET dept='{dept}', salary={salary} WHERE empno={eno}"
        )
        conn.commit()
        print("Employee updated successfully!\n")
    else:
        print("No employee found!\n")


def delete_employee():
    eno = int(input("Enter Employee Number to Delete: "))

    cursor.execute(f"SELECT * FROM emp WHERE empno={eno}")
    row = cursor.fetchone()

    if row:
        confirm = input("Are you sure to delete? (y/n): ")

        if confirm.lower() == "y":
            cursor.execute(f"DELETE FROM emp WHERE empno={eno}")
            conn.commit()
            print("Employee deleted successfully!\n")
    else:
        print("No employee found!\n")


